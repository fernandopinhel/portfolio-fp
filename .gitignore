# ═══════════════════════════════════════════════════════════════════
# .gitignore — Fernando Pinhel Portfolio
# ═══════════════════════════════════════════════════════════════════

# ── Dependências e Pacotes ──────────────────────────────────────────
node_modules/
api/node_modules/
jspm_packages/
.npm
.eslintcache

# ── Build e Produção ───────────────────────────────────────────────
dist/
dist-ssr/
*.zip
*.tar.gz
*.rar
# Ignora o dist.zip que aparece na sua estrutura para evitar lixo no repo
dist.zip 

# ── SEGURANÇA: Ambiente e Segredos (CRÍTICO) ───────────────────────
# Nunca commite arquivos que contenham chaves de API ou links privados[cite: 8, 9]
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
api/.env
api/.env.local

# ── Logs e Debug ───────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-debug.log*

# ── Editores e IDEs ────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.classpath
.project
.settings/

# ── Arquivos do Sistema Operacional ────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
desktop.ini

# ── Testes e Cobertura ─────────────────────────────────────────────
/coverage
/.nyc_output

# ── Outros ─────────────────────────────────────────────────────────
.pnpm-store/
.env.backup
.env.old