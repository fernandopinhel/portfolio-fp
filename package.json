{
  "name": "portfolio-fernando-pinhel",
  "version": "2.0.0",
  "private": true,
  "description": "Portfólio de Fernando Pinhel — Product Designer",
  "type": "module",
  "scripts": {
    "dev":      "concurrently -n FRONT,API -c cyan,green \"vite\" \"node --watch api/contact.js\"",
    "dev:front": "vite",
    "dev:api":   "node --watch api/contact.js",
    "build":    "vite build",
    "preview":  "vite preview",
    "lint":     "eslint src --ext js,jsx --report-unused-disable-directives --max-warnings 0"
  },
  "dependencies": {
    "react":     "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react":          "^18.2.0",
    "@types/react-dom":      "^18.2.0",
    "@vitejs/plugin-react":  "^4.2.0",
    "concurrently":          "^9.2.1",
    "eslint":                "^8.55.0",
    "eslint-plugin-react":   "^7.33.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "vite":                  "^5.4.0"
  }
}